# URLs publicas obligatorias para que los QR del correo carguen bien
FRONTEND_PUBLIC_URL=https://zairoclub.com
BACKEND_PUBLIC_URL=https://zairoofficial-production.up.railway.app

# Logo usado en el correo de entradas
ZAIRO_LOGO_URL=https://www.zairoclub.com/assets/zairo-loader-logo.png

# Google Wallet - se activan cuando tengas issuer y service account
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLIENT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=

# Apple Wallet - requiere Apple Developer, Pass Type ID y certificados
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_TEAM_IDENTIFIER=
APPLE_WALLET_CERT_PEM=
APPLE_WALLET_KEY_PEM=
APPLE_WWDR_PEM=
APPLE_WALLET_KEY_PASSPHRASE=
